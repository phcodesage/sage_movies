# TMDB API — required. Get a v3 key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_v3_api_key
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_IMG_URL=https://image.tmdb.org/t/p/original

# Production server (optional; defaults handled by Next.js)
PORT=3000
NODE_ENV=production

# Adsterra — ad unit codes live in components/Adsterra.tsx. Set to 'true' in the
# BUILD environment (NEXT_PUBLIC_* is inlined at build time, so setting it after a
# build does nothing). Leave false in development.
NEXT_PUBLIC_ADSTERRA_ENABLED=false
