# TMDB API — required. Get a v3 key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_v3_api_key
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_IMG_URL=https://image.tmdb.org/t/p/original

# Production server (optional; defaults handled by Next.js)
PORT=3000
NODE_ENV=production

# PopAds — the tag itself is inlined in components/PopAds.tsx (site ID 5194452).
# Set to 'true' in production to serve it. Leave false in development unless you
# want popunders on every reload.
NEXT_PUBLIC_POPADS_ENABLED=false
